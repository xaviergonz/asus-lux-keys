<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>KeyboardAmbientLight</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="HidSharpCore" Version="1.3.0" />
    <PackageReference Include="System.Management" Version="10.0.5" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\app-icon.png" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
